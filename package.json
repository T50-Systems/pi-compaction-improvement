{
  "name": "pi-compaction-improvement",
  "version": "0.1.7",
  "description": "Compaction improvement package for Pi with proactive autocompaction and richer summaries.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "compaction",
    "autocompact",
    "proactive-compaction"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:file-size": "node scripts/check-file-size.mjs",
    "validate:github-config": "node scripts/validate-github-config.mjs",
    "test:coverage": "vitest run --coverage",
    "benchmark": "vitest bench --run && npm run benchmark:summary",
    "benchmark:summary": "vitest run --config vitest.profile.config.ts"
  },
  "files": [
    "extensions",
    "src",
    "tests",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "8.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "yaml": "2.9.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
